---
/**
 * Logo Component — custom image logo
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  forceDark?: boolean;
  variant?: 'logomark' | 'full';
  class?: string;
  /** Override logo path - defaults to /logo.webp */
  logoPath?: string;
}

const {
  size = 'md',
  class: className,
  logoPath = '/logo.png',
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'w-5 h-5',
  md: 'w-6 h-6',
  lg: 'w-8 h-8',
  xl: 'w-12 h-12',
  '2xl': 'w-24 h-24',
};

const logoSize = sizeClasses[size] ?? sizeClasses.md;
---

<img
  src={logoPath}
  alt={siteConfig.branding.logo.alt}
  class={cn(
    'shrink-0 object-contain',
    logoSize,
    className
  )}
  role="img"
/>
