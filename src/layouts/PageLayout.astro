---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
  eagerReveal?: boolean;
}

const { title, description, image, imageAlt, noindex, nofollow, showScrollProgress = false, eagerReveal = false } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showActiveState
    showCta={true}
cta={{ 
  label: 'Contact', 
  href: 'mailto:contact@developer-web.com?subject=Project Inquiry&body=Hello, I would like to discuss a project.', 
  icon: 'mail', 
  trailingIcon: 'arrow-right' 
}}    showScrollProgress={showScrollProgress}
  />

  <main class="min-h-screen pt-16">
    <slot />
  </main>

  <Footer slot="footer" layout="simple" />
</BaseLayout>
