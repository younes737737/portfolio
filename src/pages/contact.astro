---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    note: 'Direct line — no forms, no delays',
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    note: 'Follow along',
    href: link.href,
    external: true,
  })),
];
---

<PageLayout
  title="Contact — Developer Web | Morocco"
  description= "Get in touch. You'll talk directly to me — the developer who builds your project. No gatekeepers, no waiting, no runaround."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      Get in touch
    </Badge>

    <h1 slot="title">
      Let's <span class="text-brand-500">talk.</span>
    </h1>

    <p slot="description">
      You'll be speaking directly with me — the developer who will actually build your project. No sales team, no handoffs, no waiting days for a reply.
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-4xl px-6">
      <div class="flex flex-col items-center gap-12">

        <!-- Calendly Widget - Centered -->
        <div class="w-full max-w-3xl" data-reveal="right">
          <Card padding="lg" class="w-full flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-6 justify-center">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="calendar" size="sm" />
              </div>
              <div>
                <h2 class="font-display text-xl font-bold text-foreground">Book a call</h2>
                <p class="text-xs text-foreground-muted">Pick a slot — I'll be there. No back-and-forth.</p>
              </div>
            </div>
            <div class="w-full">
              <!-- Calendly inline widget begin -->
              <div class="calendly-inline-widget w-full" data-url="https://calendly.com/youneselanbri12/we-re-here-to-answer-your-questions?hide_gdpr_banner=1" style="min-width:320px;height:700px;"></div>
              <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
              <!-- Calendly inline widget end -->
            </div>
          </Card>
        </div>

        <!-- The Direct Promise: numbers that kill hesitation -->
        <div class="w-full max-w-3xl" data-reveal>
          <div class="grid gap-4 md:grid-cols-3">
            <Card variant="elevated" padding="md" class="text-center">
              <p class="text-3xl font-bold text-brand-500 mb-1">&lt; 24h</p>
              <p class="text-xs text-foreground-muted leading-relaxed">average response time — you won't wait days for a reply</p>
            </Card>
            <Card variant="elevated" padding="md" class="text-center">
              <p class="text-3xl font-bold text-brand-500 mb-1">1</p>
              <p class="text-xs text-foreground-muted leading-relaxed">person to talk to — me, the developer. No chain, no noise.</p>
            </Card>
            <Card variant="elevated" padding="md" class="text-center">
              <p class="text-3xl font-bold text-brand-500 mb-1">3</p>
              <p class="text-xs text-foreground-muted leading-relaxed">languages — English, Arabic, French. Whichever you prefer.</p>
            </Card>
          </div>
        </div>

        <!-- Contact channels - Below -->
        <div class="w-full max-w-2xl" data-reveal="left" data-reveal-delay="1">
          <div class="text-center mb-6">
            <h2 class="font-display text-lg font-bold text-foreground mb-1">Other ways to reach me</h2>
            <p class="text-sm text-foreground-muted">Prefer a direct line? Choose what works for you.</p>
          </div>

          <!-- Channel list -->
          <div class="space-y-2">
            {channels.map((ch) => (
              <a
                href={ch.href}
                {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                class="block group"
              >
                <Card hover padding="sm" class="h-full">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                      <Icon name={ch.icon} size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground">{ch.label}</p>
                      <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            ))}
          </div>

          <!-- Location card -->
          <Card hover padding="sm" class="bg-brand-500/5 border-brand-500/20 mt-2">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="map-pin" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">{siteConfig.address?.city ?? 'Your City'}</p>
                <p class="text-xs text-foreground-muted mt-0.5">Based in {siteConfig.address?.country ?? 'Your Country'} — working worldwide</p>
              </div>
            </div>
          </Card>

        </div>

      </div>
    </div>
  </section>
</PageLayout>
