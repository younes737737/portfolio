---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';
import Progress from '@/components/ui/data-display/Progress/Progress.astro';

const technologies = [
  {
    title: 'Laravel & PHP',
    description: 'PHP framework with Eloquent ORM, Blade templating, and a robust ecosystem',
    devIcon: 'laravel',
    category: 'Backend',
    level: 'Expert',
    years: 2,
    color: '#FF2D20',
  },
  {
    title: 'React',
    description: 'Component-based architecture with SSR, RSC, and App Router',
    devIcon: 'react',
    category: 'Frontend',
    level: 'Expert',
    years: 2,
    color: '#61DAFB',
    featured: false,
  },
  {
    title: 'JavaScript / TypeScript',
    description: 'Modern JavaScript with full TypeScript type safety across the stack',
    devIcon: 'javascript',
    category: 'Frontend',
    level: 'Expert',
    years: 2,
    color: '#F7DF1E',
  },
  {
    title: 'WordPress & Figma',
    description: 'Custom WordPress development and modern UI/UX design with Figma',
    devIcon: 'wordpress',
    category: 'Frontend',
    level: 'Avancé',
    years: 2,
    color: '#21759B',
  },
  {
    title: 'Tailwind CSS & Bootstrap 5',
    description: 'Utility-first CSS, design systems, and responsive UI development',
    devIcon: 'tailwindcss',
    category: 'Frontend',
    level: 'Expert',
    years: 2,
    color: '#06B6D4',
  },
  {
    title: 'MySQL, NoSQL & MongoDB',
    description: 'Relational and NoSQL database design, indexing, and performance optimization',
    devIcon: 'mysql',
    category: 'Backend',
    level: 'Avancé',
    years: 2,
    color: '#4169E1',
  },
  {
    title: 'Git & CI/CD',
    description: 'Version control, GitHub Actions, automated testing, and deployment pipelines',
    devIcon: 'git',
    category: 'DevOps',
    level: 'Expert',
    years: 2,
    color: '#F05032',
  },
  {
    title: 'Jira',
    description: 'Project management and issue tracking',
    devIcon: 'jira',
    category: 'DevOps',
    level: 'Expert',
    years: 2,
    color: '#0052CC',
  },
];

const categoryMeta = {
  Frontend: {
    color: '#FF2D20',
    bg: 'rgba(124,58,237,0.08)',
    text: '#6D28D9',
    desc: 'Interfaces & user experiences',
  },
  Backend: {
    color: '#059669',
    bg: 'rgba(5,150,105,0.08)',
    text: '#047857',
    desc: 'Databases & business logic',
  },
  DevOps: {
    color: '#2563EB',
    bg: 'rgba(37,99,235,0.08)',
    text: '#1D4ED8',
    desc: 'Infrastructure, CI/CD & deployments',
  },
};
const allCategories = ['All', 'Frontend', 'Backend', 'DevOps'];
const levelConfig = {
  Expert: { pct: 95, color: '#059669', bg: 'rgba(5,150,105,0.08)', text: '#065F46' },
  Avancé: { pct: 78, color: '#2563EB', bg: 'rgba(37,99,235,0.08)', text: '#1E40AF' },
};
const projectItems = await getCollection('projects');
const featuredProjects = projectItems.sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Developer Web — Engineering Digital Excellence"
  description="Busy building premium websites for businesses. We combine technical discipline with creative excellence to engineer digital tools that solve business problems."
  image="/logo.webp"
  includeOrgSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>
    <h1 slot="title">
      <span class="text-brand-500 dark:text-foreground [-webkit-text-fill-color:currentColor]"
        >Developer Web —</span
      ><br />
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Digital Excellence</span
      ><span class="text-foreground [-webkit-text-fill-color:currentColor]">
        &amp; Business Solutions</span
      >
    </h1>

    <p slot="description">Your website should bring clients in. Not just look good.</p>

    <Fragment slot="actions">
      <Button size="lg" href="/projects">
        Our Premium Work
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/contact">
        <Icon name="mail" size="sm" />
        Start Your Project
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services Section -->
  <section
    class="bg-background-secondary border-border relative z-10 border-t py-[var(--space-section-md)]"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Services</Badge>
          <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
            We handle everything. <span class="text-brand-500">You focus on your business.</span>
          </h2>
        </div>
        <p class="text-foreground-muted mx-auto max-w-2xl text-lg">
          Every project is engineered with clean architecture, security best practices, and
          long-term maintainability — not just delivered, but continuously improved.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Custom Website Development -->
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div
              class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
            >
              <Icon name="layout" size="lg" />
            </div>
            <div class="min-w-65 flex-1">
              <h3 class="text-foreground text-base font-semibold">
                01. Custom Website Development
              </h3>
              <p class="text-foreground-muted mt-1.5 text-sm leading-relaxed">
                Fast, Clean and modern websites built from scratch that look great on every screen.
                Focused on clarity, usability, and your brand identity.
              </p>
            </div>
          </div>
        </Card>

        <!-- Security & Maintenance -->
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div
              class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
            >
              <Icon name="code" size="lg" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-foreground text-base font-semibold">02. Security & Maintenance</h3>
              <p class="text-foreground-muted mt-1.5 text-sm leading-relaxed">
                Continuous updates, monitoring, and protection to keep your website fast, secure,
                and reliable. Accessible websites built with secure tooling.
              </p>
            </div>
          </div>
        </Card>

        <!-- Performance -->
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div
              class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
            >
              <Icon name="zap" size="lg" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-foreground text-base font-semibold">03. Web Applications</h3>
              <p class="text-foreground-muted mt-1.5 text-sm leading-relaxed">
                Custom systems designed to handle real business logic. <br />Scalable, maintainable,
                and built for long-term use.
              </p>
            </div>
          </div>
        </Card>
      </div>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button
          variant="primary"
          href="/contact"
          class="mt-6 flex max-w-50 items-center justify-center"
          >Let's get started <Icon name="arrow-right" size="lg" /></Button
        >
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="bg-background border-border relative z-10 border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center" data-reveal="right">
          <div class="mb-6 flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">About me</Badge>
            <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
              Full-Stack Web<br />
              <span class="text-brand-500">Developer</span>
            </h2>
          </div>
          <p class="text-foreground-muted mb-4 text-lg leading-relaxed">
            I'm Youness, a web developer dedicated to turning ideas into creative solutions. I
            specialize in creating seamless and intuitive websites. I'm involved in every step of
            the process — from discovery and design to <span class="font-bold"
              >development, testing, and deployment</span
            >. I focus on delivering high-quality, scalable results with clear communication and
            reliable support. Available for clients worldwide.
          </p>
          <p class="text-foreground-muted mb-8 text-lg leading-relaxed">
            Insights, process, and decisions behind my work.
          </p>
          <Button variant="outline" href="/blog" class="self-start"> Read more </Button>
        </div>
        <Card
          variant="elevated"
          padding="lg"
          class="flex h-full flex-col"
          data-reveal="left"
          data-reveal-delay="1"
        >
          <img src="/about2.jpg" alt="About me" class="h-full w-full object-cover" />
        </Card>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGIES -->
  <!-- ============================================================ -->
  <!-- TECHNOLOGIES — filter-based design                           -->
  <!-- ============================================================ -->
  <section
    class="tech-section bg-background-secondary border-border relative z-10 border-t py-[var(--space-section-md)]"
  >
    <div class="mx-auto max-w-6xl px-6">
      <!-- Header -->
      <div class="tech-header mb-10 flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Stack technique</Badge>
        <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
          Technologies & Expertise
        </h2>
        <p class="text-foreground-muted mx-auto max-w-2xl text-lg">
          Tools I use in production — with real proficiency levels, not just logos
        </p>
      </div>

      <!-- Filter bar -->
      <div
        class="tech-filterbar mb-4 flex flex-wrap justify-center gap-1"
        role="group"
        aria-label="Filter by category"
      >
        {
          allCategories.map((cat) => (
            <button
              class={`tech-filter-btn ${cat === 'All' ? 'active' : ''}`}
              data-filter={cat}
              aria-pressed={cat === 'All' ? 'true' : 'false'}
            >
              {cat !== 'All' && (
                <span
                  class="tech-filter-dot"
                  style={`background: ${categoryMeta[cat as keyof typeof categoryMeta]?.color}`}
                />
              )}
              {cat}
            </button>
          ))
        }
      </div>

      <!-- Context line -->
      <p
        class="tech-ctx text-foreground-muted mb-8 text-center text-sm"
        id="tech-ctx"
        aria-live="polite"
      >
        All technologies — <strong class="text-foreground">{technologies.length} total</strong>
      </p>

      <!-- Grid -->
      <div class="tech-grid" id="tech-grid" role="list">
        {
          technologies.map((tech, i) => {
            const lc = levelConfig[tech.level as keyof typeof levelConfig];
            const cm = categoryMeta[tech.category as keyof typeof categoryMeta];
            return (
              <article
                class={`tech-card${tech.featured ? 'featured' : ''}`}
                data-category={tech.category}
                role="listitem"
                style={`--card-accent: ${tech.color}; --cat-color: ${cm.color}; animation-delay: ${i * 40}ms`}
              >
                {tech.featured && (
                  <span class="tech-featured-badge" style={`background: ${cm.color}`}>
                    Main
                  </span>
                )}

                <div class="tech-card-top">
                  <div
                    class="tech-icon"
                    style={`background: ${tech.color}18; color: ${tech.color}`}
                  >
                    <Icon name={tech.devIcon} useDevIcon={true} class="h-5 w-5" />
                  </div>
                  <span class="tech-cat-tag" style={`background: ${cm.bg}; color: ${cm.text}`}>
                    {tech.category}
                  </span>
                </div>

                <h3 class="tech-card-title">{tech.title}</h3>
                <p class="tech-card-desc">{tech.description}</p>

                <div class="tech-card-footer">
                  <div class="tech-level-row">
                    <div class="tech-level-left">
                      <span
                        class="tech-level-badge"
                        style={`background: ${lc.bg}; color: ${lc.text}`}
                      >
                        {tech.level}
                      </span>
                      <span class="tech-years">
                        {tech.years} yr{tech.years > 1 ? 's' : ''}
                      </span>
                    </div>
                    <span class="tech-level-pct" style={`color: ${lc.color}`}>
                      {lc.pct}%
                    </span>
                  </div>
                  <div class="tech-level-track">
                    <div
                      class="tech-level-fill"
                      style={`width: ${lc.pct}%; background: ${lc.color}`}
                      role="progressbar"
                      aria-valuenow={lc.pct}
                      aria-valuemin={0}
                      aria-valuemax={100}
                      aria-label={`${tech.level} — ${lc.pct}%`}
                    />
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>

      <!-- Empty state -->
      <p class="tech-empty text-foreground-muted hidden py-16 text-center text-sm" id="tech-empty">
        No technologies in this category.
      </p>
    </div>
  </section>

  <section class="bg-background border-border relative z-10 border-t py-[var(--space-section-md)]">
    <div class="flex flex-col items-center gap-4 text-center" data-reveal>
      <div class="flex flex-col items-center gap-6">
        <Badge variant="brand" pill>Let's talk</Badge>
        <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
          Let's talk about your project
        </h2>
      </div>
      <p class="text-foreground-muted text-lg">
        Let's discuss your project and find the best solution for you.
      </p>
    </div>
    <!-- Calendly link widget begin -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async
    ></script>
    <div class="flex flex-col justify-center gap-2 sm:flex-row">
      <Button
        variant="primary"
        class="hover:bg-brand-500 mt-6 flex max-w-50 cursor-pointer items-center justify-center transition-all duration-300 hover:scale-105 hover:scale-150 hover:text-white"
        onclick="if(window.Calendly){ Calendly.initPopupWidget({url: 'https://calendly.com/youneselanbri12/we-re-here-to-answer-your-questions'}); } return false;"
      >
        Get Started
      </Button>
    </div>
    <!-- Calendly link widget end -->
  </section>

  <!-- Portfolio -->
  <section
    id="work"
    class="bg-background-secondary border-border relative z-10 border-t py-[var(--space-section-md)]"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Selected work</Badge>
          <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
            Projects I've built
          </h2>
        </div>
        <p class="text-foreground-muted mx-auto max-w-2xl text-lg">A selection of recent work.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          featuredProjects.map((project) => (
            <Card
              variant="elevated"
              hover
              padding="lg"
              href={`/projects/${project.id.replace(/\.mdx?$/, '')}`}
              class="group flex flex-col"
              data-reveal
            >
              <div class="flex flex-1 flex-col">
                <div class="mb-3 flex items-start justify-between gap-4">
                  <div class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br">
                    <Icon name="layers" size="sm" />
                  </div>
                  <Icon
                    name="arrow-up-right"
                    size="sm"
                    class="text-foreground-muted group-hover:text-brand-500 shrink-0 transition-colors"
                  />
                </div>
                <div class="mb-2 flex items-baseline gap-2">
                  <h3 class="font-display text-foreground text-lg font-bold">
                    {project.data.title}
                  </h3>
                  {project.data.year && (
                    <span class="text-foreground-muted text-xs">{project.data.year}</span>
                  )}
                </div>
                <p class="text-foreground-muted mb-4 flex-1 text-sm leading-relaxed">
                  {project.data.description}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {project.data.tags.map((tag) => (
                    <Badge variant="brand">{tag}</Badge>
                  ))}
                </div>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-background border-border relative z-10 border-t py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Testimonials</Badge>
          <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">
            What clients say
          </h2>
        </div>
        <p class="text-foreground-muted text-lg">Replace these with your own client quotes.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Testimonial 1 -->
        <Card variant="elevated" padding="lg" hover data-reveal>
          <div class="flex h-full flex-col gap-4">
            <div class="text-brand-500 flex gap-1" role="img" aria-label="5 out of 5 stars">
              {
                [...Array(5)].map(() => (
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))
              }
            </div>
            <blockquote class="text-foreground-muted flex-1 leading-relaxed">
              "The new site launched on time and hit every goal we set. Performance improved
              dramatically — load times dropped and the feedback from our customers has been
              overwhelmingly positive."
            </blockquote>
            <div class="border-border flex items-center gap-3 border-t pt-4">
              <div
                class="from-brand-500/30 to-brand-500/10 text-brand-500 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br text-sm font-bold"
              >
                A
              </div>
              <div>
                <p class="text-foreground text-sm font-semibold">Alex Morgan</p>
                <p class="text-foreground-muted text-xs">Founder, Bright Studio</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2 -->
        <Card variant="elevated" padding="lg" hover data-reveal data-reveal-delay="1">
          <div class="flex h-full flex-col gap-4">
            <div class="text-brand-500 flex gap-1" role="img" aria-label="5 out of 5 stars">
              {
                [...Array(5)].map(() => (
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))
              }
            </div>
            <blockquote class="text-foreground-muted flex-1 leading-relaxed">
              "Straightforward from first conversation to final handover. The right questions were
              asked, we were kept in the loop throughout, and the end result exceeded what we
              imagined. Would recommend without hesitation."
            </blockquote>
            <div class="border-border flex items-center gap-3 border-t pt-4">
              <div
                class="from-brand-500/30 to-brand-500/10 text-brand-500 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br text-sm font-bold"
              >
                S
              </div>
              <div>
                <p class="text-foreground text-sm font-semibold">Sarah Chen</p>
                <p class="text-foreground-muted text-xs">CEO, Luma Agency</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section
    class="bg-background-secondary border-border relative z-10 border-t py-[var(--space-section-md)]"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start">From the blog</Badge>
          <h2 class="font-display text-foreground text-3xl font-bold md:text-4xl">Featured</h2>
        </div>
        <a
          href="/blog"
          class="text-brand-500 hover:text-brand-600 hidden shrink-0 items-center gap-1.5 text-sm font-medium transition-colors sm:inline-flex"
        >
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {
          posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${post.id.replace('en/', '')}`}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              svgSlug={post.data.svgSlug}
            />
          ))
        }
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-background relative z-10 py-[var(--space-section-md)]">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
