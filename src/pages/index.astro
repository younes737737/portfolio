  </section>
  <style>
    .tech-stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      border-radius: 100px;
      border: none;
      background: var(--pill-bg);
      color: var(--pill-text);
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition:
        transform 0.15s,
        opacity 0.15s;
    }
    .tech-stat-pill:hover {
      transform: translateY(-1px);
    }

    .tech-stat-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .tech-stat-count {
      background: rgba(0, 0, 0, 0.07);
      padding: 1px 6px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 700;
    }

    .tech-filterbar {
      padding: 3px;
      background: var(--color-background-tertiary, rgba(0, 0, 0, 0.04));
      border-radius: 12px;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
    }

    .tech-filter-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 18px;
      border-radius: 9px;
      border: none;
      background: transparent;
      color: var(--color-foreground-muted);
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.18s;
    }
    .tech-filter-btn:hover:not(.active) {
      background: rgba(255, 255, 255, 0.6);
      color: var(--color-foreground);
    }
    .tech-filter-btn.active {
      background: var(--color-background);
      color: var(--color-foreground);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
    }

    .tech-filter-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .tech-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }

    .tech-card {
      position: relative;
      background: var(--color-background);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 1.25rem;
      transition:
        transform 0.2s,
        box-shadow 0.2s,
        border-color 0.2s;
      animation: techCardIn 0.35s ease both;
    }
    .tech-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
      border-color: var(--card-accent);
    }
    .tech-card.featured {
      border-color: var(--cat-color);
      border-width: 1.5px;
    }
    .tech-card.tech-hidden {
      display: none !important;
    }

    @keyframes techCardIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .tech-card {
        animation: none;
      }
    }

    .tech-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .tech-icon {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .tech-cat-tag {
      font-size: 0.68rem;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 20px;
      letter-spacing: 0.03em;
    }

    .tech-card-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--color-foreground);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }

    .tech-card-desc {
      font-size: 0.78rem;
      color: var(--color-foreground-muted);
      line-height: 1.55;
      margin-bottom: 1rem;
      min-height: 2.5rem;
    }

    .tech-level-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 6px;
    }

    .tech-level-left {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .tech-level-badge {
      font-size: 0.68rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 20px;
    }

    .tech-years {
      font-size: 0.7rem;
      color: var(--color-foreground-muted);
    }

    .tech-level-pct {
      font-size: 0.72rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    .tech-level-track {
      height: 3px;
      background: var(--color-border);
      border-radius: 2px;
      overflow: hidden;
    }

    .tech-level-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .tech-featured-badge {
      position: absolute;
      top: 11px;
      right: 11px;
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      padding: 2px 7px;
      border-radius: 20px;
      color: white;
    }
  </style>
  <script>
    function initCountup() {
      const counters = document.querySelectorAll<HTMLElement>(
        '[data-countup]:not([data-countup-init])'
      );
      if (counters.length === 0) return;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            observer.unobserve(entry.target);
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.countup ?? '0', 10);
            const suffix = el.dataset.suffix ?? '';
            const duration = 1200;
            const start = performance.now();
            const tick = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          });
        },
        { threshold: 0.4 }
      );
      counters.forEach((el) => {
        el.dataset.countupInit = 'true';
        observer.observe(el);
      });
    }

    initCountup();
  </script>
  <script>
    const categoryDescriptions: Record<string, string> = {
      All: 'All technologies',
      Frontend: 'Interfaces & user experiences',
      Backend: 'Databases & business logic',
      DevOps: 'Infrastructure, CI/CD & deployments',
    };

    const cards = document.querySelectorAll<HTMLElement>('.tech-card');
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tech-filter-btn');
    const statPills = document.querySelectorAll<HTMLButtonElement>('.tech-stat-pill');
    const ctxEl = document.getElementById('tech-ctx');
    const emptyEl = document.getElementById('tech-empty');

    function applyFilter(cat: string) {
      let visible = 0;
      cards.forEach((card) => {
        const match = cat === 'All' || card.dataset.category === cat;
        card.classList.toggle('tech-hidden', !match);
        if (match) visible++;
      });
      filterBtns.forEach((btn) => {
        const active = btn.dataset.filter === cat;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-pressed', String(active));
      });
      if (ctxEl) {
        const desc = categoryDescriptions[cat] ?? cat;
        ctxEl.innerHTML = `${desc} — <strong>${visible} technolog${visible > 1 ? 'ies' : 'y'}</strong>`;
      }
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'All'));
    });
    statPills.forEach((pill) => {
      pill.addEventListener('click', () => applyFilter(pill.dataset.filter ?? 'All'));
    });
  </script>
</LandingLayout>
